#!/bin/bash
# Git Pre-commit Hook for RFC8762 Project
#
# チェック内容:
# - 末尾の空白を削除
# - ファイルの末行を改行で終わらせる
# - ファイルのエンコーディング（UTF-8）
# - 改行コード（LF）
# - インデント（.editorconfig に基づく）
# - マージコンフリクト残骸

set -e

# カラー出力
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS=0
WARNINGS=0
FIXED_FILES=()

echo -e "${GREEN}=== Pre-commit Hook ===${NC}"
echo ""

# ステージング済みのファイルを取得（.githooks を除外）
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
STAGED_FILES=$(echo "$STAGED_FILES" | grep -v '^\.githooks/')

if [ -z "$STAGED_FILES" ]; then
    echo "No staged files to check."
    exit 0
fi

# === チェック 1: マージコンフリクト残骸 ===
echo -n "Checking for merge conflicts... "
CONFLICT_FILES=$(echo "$STAGED_FILES" | xargs grep -l '<<<<<<< HEAD' 2>/dev/null || true)
if [ -n "$CONFLICT_FILES" ]; then
    echo -e "${RED}FAILED${NC}"
    echo "  マージコンフリクト残骸が見つかりました："
    echo "$CONFLICT_FILES" | while read file; do echo "    - $file"; done
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}OK${NC}"
fi

# === チェック 2: 末尾の空白削除 ===
echo -n "Removing trailing whitespace... "
TRAILING_WS_FILES=()
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        if grep -q '[[:space:]]$' "$file" 2>/dev/null; then
            TRAILING_WS_FILES+=("$file")
            sed -i 's/[[:space:]]*$//' "$file"
        fi
    fi
done

if [ ${#TRAILING_WS_FILES[@]} -gt 0 ]; then
    echo -e "${YELLOW}FIXED${NC}"
    echo "  Modified: ${TRAILING_WS_FILES[@]}"
    git add "${TRAILING_WS_FILES[@]}"
else
    echo -e "${GREEN}OK${NC}"
fi

# === チェック 3: ファイルの末行を改行で終わらせる ===
echo -n "Checking final newline... "
NEWLINE_FILES=()
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # バイナリファイルをスキップ
        if file "$file" | grep -q "text"; then
            if [ -s "$file" ] && [ -n "$(tail -c 1 "$file")" ]; then
                NEWLINE_FILES+=("$file")
                echo >> "$file"
            fi
        fi
    fi
done

if [ ${#NEWLINE_FILES[@]} -gt 0 ]; then
    echo -e "${YELLOW}FIXED${NC}"
    echo "  Modified: ${NEWLINE_FILES[@]}"
    git add "${NEWLINE_FILES[@]}"
else
    echo -e "${GREEN}OK${NC}"
fi

# === チェック 4: エンコーディング（UTF-8）チェック ===
echo -n "Checking file encoding (UTF-8)... "
ENCODING_ERRORS=()
for file in $STAGED_FILES; do
    if [ -f "$file" ] && file "$file" | grep -q "text"; then
        # UTF-8 でないファイルを検出
        encoding=$(file -b --mime-encoding "$file")
        if [ "$encoding" != "utf-8" ] && [ "$encoding" != "ascii" ]; then
            ENCODING_ERRORS+=("$file ($encoding)")
        fi
    fi
done

if [ ${#ENCODING_ERRORS[@]} -gt 0 ]; then
    echo -e "${RED}FAILED${NC}"
    echo "  UTF-8 以外のエンコーディングが見つかりました："
    for err in "${ENCODING_ERRORS[@]}"; do
        echo "    - $err"
    done
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}OK${NC}"
fi

# === チェック 5: 改行コード（LF チェック）===
echo -n "Checking line endings (LF)... "
CRLF_FILES=()
for file in $STAGED_FILES; do
    if [ -f "$file" ] && file "$file" | grep -q "text"; then
        if grep -q $'\r' "$file" 2>/dev/null; then
            CRLF_FILES+=("$file")
            # CRLF を LF に変換
            dos2unix "$file" 2>/dev/null || sed -i 's/\r$//' "$file"
        fi
    fi
done

if [ ${#CRLF_FILES[@]} -gt 0 ]; then
    echo -e "${YELLOW}FIXED${NC}"
    echo "  CRLF to LF converted: ${CRLF_FILES[@]}"
    git add "${CRLF_FILES[@]}"
else
    echo -e "${GREEN}OK${NC}"
fi

# === チェック 6: .editorconfig ルールのチェック（簡易版）===
echo -n "Checking indentation (.editorconfig)... "
INDENT_WARNINGS=()

for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # C ファイル (indent_style = space, indent_size = 4)
        if [[ "$file" =~ \.(c|h)$ ]]; then
            if grep -q $'\t' "$file" 2>/dev/null; then
                INDENT_WARNINGS+=("$file (detected TAB, should use SPACE)")
            fi
        fi

        # Markdown ファイル (indent_style = tab)
        if [[ "$file" =~ \.md$ ]]; then
            # Markdown はタブでもスペースでも OK（チェックスキップ）
            :
        fi
    fi
done

if [ ${#INDENT_WARNINGS[@]} -gt 0 ]; then
    echo -e "${YELLOW}WARNINGS${NC}"
    echo "  インデント規則の警告："
    for warn in "${INDENT_WARNINGS[@]}"; do
        echo "    - $warn"
    done
    WARNINGS=$((WARNINGS + 1))
else
    echo -e "${GREEN}OK${NC}"
fi

# === 結果出力 ===
echo ""
echo -e "${GREEN}=== Check Complete ===${NC}"

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}✗ $ERRORS error(s) found${NC}"
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠ $WARNINGS warning(s) found${NC}"
    echo "  コミットは続行されます"
    exit 0
else
    echo -e "${GREEN}✓ All checks passed!${NC}"
    exit 0
fi
